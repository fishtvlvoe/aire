{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/license/:path*", "destination": "/api/license/:path*" },
    { "source": "/features/:path*", "destination": "/api/features/:path*" },
    { "source": "/updates/:path*", "destination": "/api/updates/:path*" }
  ]
}
