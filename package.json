{
  "name": "aire",
  "version": "0.1.2",
  "private": true,
  "main": "electron/build/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "cleanup:drafts": "tsx scripts/cleanup-empty-drafts.ts",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:build": "npm run build && node scripts/obfuscate-build.js && npm run electron:compile && node -e \"if(!require('fs').existsSync('.next/standalone/server.js')){console.error('ERROR: .next/standalone/server.js not found. Run next build first.');process.exit(1)}\" && electron-builder --config electron-builder.json",
    "electron:pack:mac": "electron-builder --mac --config electron-builder.json",
    "electron:pack:win": "electron-builder --win --config electron-builder.json",
    "postinstall": "node -e \"console.log('skip: chromium download managed externally')\""
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@sparticuz/chromium": "131.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.6.2",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.1",
    "next": "16.2.4",
    "next-auth": "4.24.11",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "puppeteer-core": "23.11.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.3",
    "yaml": "^2.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "javascript-obfuscator": "^5.4.2",
    "jsdom": "^29.0.2",
    "png2icons": "^2.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "fishtvlvoe",
        "repo": "aire"
      }
    ]
  }
}
