# ===== Database =====
# SQLite 檔案路徑（必填，本機開發用）
DB_PATH=./data/listings.db

# Docker 環境覆蓋用，優先於 DB_PATH（測試環境設 :memory:）
DATABASE_PATH=

# ===== LLM Backend =====
# AI 後端選擇：codex / claude-code / gemini / ollama
LLM_BACKEND=codex

# 使用 codex 後端時必填
CODEX_API_KEY=your_codex_api_key_here

# ===== Puppeteer / Chromium（PDF 生成用）=====
# Chromium 啟動模式：local（系統 chromium）/ serverless（@sparticuz/chromium）
CHROMIUM_MODE=local

# 可選，指定 Chromium 路徑（Docker 內或非標準安裝位置）
PUPPETEER_EXECUTABLE_PATH=

# 可選，Puppeteer 替代變數（部分環境用此名稱）
CHROMIUM_PATH=

# ===== Document Generation =====
# 可選，不動產說明書 PDF 的 logo 圖檔路徑
DOSSIER_LOGO_PATH=

# 可選，上傳/輸出根目錄（attachments、PDF 等）
DATA_ROOT=./data

# OCR 信心值門檻：低於此值的自動辨識欄位會留空白（待補），避免亂碼滲入 PDF
# 範圍 0.0–1.0，預設 0.80（PDF 文字層直接萃取約 0.95，LLM Vision fallback 約 0.70）
OCR_CONFIDENCE_THRESHOLD=0.80

# ===== Server =====
# 可選，Next.js 監聽埠
PORT=3000

# ===== Auth.js / NextAuth =====
# 生產環境請使用高熵隨機字串（至少 32 bytes）
NEXTAUTH_SECRET=
# Auth callback base URL（本機開發可用 http://localhost:3000）
NEXTAUTH_URL=

# 啟動時自動 seed 總管理員帳號（必填）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password

# 客戶登入授權序號驗簽公鑰（Ed25519, PEM 格式）
LICENSE_PUBLIC_KEY=

# 忘記密碼寄信來源地址（toSend API）
TOSEND_FROM_EMAIL=fish@aiver.me

# ===== Cloud Data API（hybrid-architecture，Wave 3 追加實際值）=====
# 雲端公開資料 API 位址；未設定 → 客戶端自動降級回本地計算
DATA_API_URL=
